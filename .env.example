# ============================================================
#  OpenClaw 工作台  环境变量配置模板
#  用法：复制本文件为 .env，按需填写。标【必填】的不配会起不来；其余可留空用默认。
# ============================================================

# ─────────────────── 【必填】网关连接 ───────────────────
# OpenClaw 网关（gateway）地址。本机默认 18789。
VITE_GATEWAY_URL=http://127.0.0.1:18789          # 网关 HTTP API
VITE_WS_URL=ws://127.0.0.1:18789                 # 网关 WebSocket
VITE_GATEWAY_TOKEN=your_gateway_token_here       # 网关访问 token（openclaw 配置里拿）
# 后端（unified-service.js）也会用到同一个 token，二选一/都填：
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# ─────────────────── 【必填】端口 ───────────────────
# 前端开发/预览端口、后端统一服务端口。改了要和下面的 BACKEND_URL 对应。
FRONTEND_PORT=31021                              # 前端端口（vite dev/preview）
BACKEND_PORT=31022                               # 后端统一服务端口（unified-service.js）
# 后端 API 地址（前端调用）。端口要和 BACKEND_PORT 一致。
VITE_BACKEND_URL=http://127.0.0.1:31022

# ─────────────────── 用户 / Agent 显示名 ───────────────────
# 你在界面里的称呼（不填则用默认）。开源/分享版留空即可。
VITE_USER_NAME=
VITE_USER_DISPLAY_NAME=
# Agent 中文称呼（API 失败时的降级显示）。格式 VITE_AGENT_<id>=名称（id 里连字符换下划线）。
# VITE_AGENT_main=助手
# VITE_AGENT_pm=产品经理
# VITE_AGENT_developer=开发工程师
# VITE_AGENT_tester=测试工程师
# VITE_AGENT_inspector=巡检员
# VITE_AGENT_archivist=档案员
# VITE_AGENT_designer=设计师

# ─────────────────── 计费模式（费用统计）───────────────────
# electricity=本地模型(API费+电费) / subscription=订阅(API费+月费分摊) / api_only=仅API费
VITE_COST_MODE=electricity
VITE_ELECTRICITY_PER_HOUR=2                       # 电费(元/小时)，仅 electricity 生效
VITE_SUBSCRIPTION_MONTHLY_CNY=280                # 月订阅总额(元)，仅 subscription 生效

# ─────────────────── HTTPS / 远程访问（选填）───────────────────
# 远程电脑用语音功能必须 HTTPS：npm run start:v2:https
OPENCLAW_HTTPS=0                                  # 1=启用本地自签 HTTPS
OPENCLAW_HTTPS_FRONTEND_PORT=31023               # HTTPS 前端端口
# 受信任的 HTTPS 来源（远程访问域名，如自建/内网穿透域名）。本机用可留空。
OPENCLAW_TRUSTED_HTTPS_ORIGIN=
VITE_OPENCLAW_TRUSTED_HTTPS_ORIGIN=

# ─────────────────── 语音·听（STT 语音识别，选填）───────────────────
# 浏览器优先用内置识别；不支持时按下面 fallback。
# 方案A：本地命令，stdout 直接输出文字，{input}=临时音频路径
# 例：OPENCLAW_VOICE_STT_COMMAND=whisper {input} --language Chinese --model base --output_format txt --output_dir /tmp/o && cat /tmp/o/*.txt
OPENCLAW_VOICE_STT_COMMAND=
# 方案B：OpenAI 兼容转写接口
OPENCLAW_VOICE_STT_API_KEY=
OPENCLAW_VOICE_STT_ENDPOINT=
OPENCLAW_VOICE_STT_MODEL=whisper-1
OPENCLAW_VOICE_STT_LANGUAGE=zh
OPENCLAW_VOICE_LANGUAGE=Chinese
OPENCLAW_VOICE_STT_TIMEOUT_MS=120000
# 阿里实时识别/本地 whisper 模型名（用对应方案时填）
OPENCLAW_VOICE_ASR_REALTIME_MODEL=paraformer-realtime-v2
OPENCLAW_VOICE_QWEN_ASR_MODEL=qwen3-asr-flash
OPENCLAW_VOICE_WHISPER_MODEL=small

# ─────────────────── 语音·说（TTS 合成，选填）───────────────────
# auto=优先 CosyVoice，其次 GPT-SoVITS，再其次自定义命令
OPENCLAW_VOICE_TTS_PROVIDER=auto
OPENCLAW_VOICE_TTS_TIMEOUT_MS=120000
# 由大模型判断该用什么情绪朗读（选填）
OPENCLAW_VOICE_EMOTION_MODEL=

# 方案A：阿里 DashScope CosyVoice（云端克隆+合成）
OPENCLAW_VOICE_DASHSCOPE_API_KEY=
OPENCLAW_COSYVOICE_TARGET_MODEL=cosyvoice-v3-flash
OPENCLAW_COSYVOICE_TTS_MODEL=cosyvoice-v3-flash

# 方案B：MiniMax（云端 TTS + 克隆）
OPENCLAW_VOICE_MINIMAX_API_KEY=
OPENCLAW_VOICE_MINIMAX_GROUP_ID=
OPENCLAW_VOICE_MINIMAX_BASE_URL=https://api.minimaxi.com
OPENCLAW_VOICE_MINIMAX_MODEL=speech-2.6-hd
OPENCLAW_VOICE_MINIMAX_VOICE=female-tianmei      # 预制音色 voice_id
OPENCLAW_VOICE_MINIMAX_CLONE_API_KEY=            # 声音克隆用(可与上面同一个key)

# 方案C：本地 GPT-SoVITS。例：http://127.0.0.1:9880
OPENCLAW_GPTSOVITS_URL=
OPENCLAW_GPTSOVITS_PROMPT_TEXT=你好，这是我的声音样本。

# 方案D：自定义本地 TTS 命令（必须产出音频文件）
# 占位：{text} {voiceId} {voiceName} {sample} {output}
# 例：OPENCLAW_VOICE_TTS_COMMAND=/path/to/tts --text {text} --ref {sample} --out {output}
OPENCLAW_VOICE_TTS_COMMAND=

# ─────────────────── 其他（选填）───────────────────
# 「分享此版本」按钮：按版本通道拼部署链接（${仓库}/releases/tag/v${版本号}）。
# 分通道配两个仓库——正式版指向 stable 仓库，内测版指向 beta 仓库（各版本要在对应仓库建好 release）。
VITE_SHARE_REPO_URL_STABLE=https://github.com/<你的用户名>/<正式版仓库>
VITE_SHARE_REPO_URL_BETA=https://github.com/<你的用户名>/<内测版仓库>
# 旧的单一变量（向后兼容）：上面两个都没配时才回退用它。
VITE_SHARE_REPO_URL=
