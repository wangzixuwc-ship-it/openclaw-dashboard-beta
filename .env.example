VITE_GATEWAY_URL=http://127.0.0.1:18789 # OpenClaw 系统 API 地址
VITE_WS_URL=ws://127.0.0.1:18789 # OpenClaw 系统 WebSocket 地址
VITE_GATEWAY_TOKEN=your_gateway_token_here # OpenClaw 系统 API Token
# ─────────────────── 计费模式（费用统计）───────────────────
# VITE_COST_MODE 可选值：
#   electricity   - 本地模型部署用：费用 = API 实际费用 + 电费（uptime × 元/小时）
#   subscription  - 订阅 API 用：费用 = API 实际费用 + 月订阅费按运行时长比例分摊
#   api_only      - 纯 API 计费：费用 = API 实际费用（不附加任何成本）
# 默认 electricity（兼容原作者本地模型逻辑）
VITE_COST_MODE=electricity

# 电费单价（元/小时）—— 仅 VITE_COST_MODE=electricity 时生效
VITE_ELECTRICITY_PER_HOUR=2

# 月订阅总费用（元/月）—— 仅 VITE_COST_MODE=subscription 时生效
# 示例：ChatGPT Plus 约 ¥140 + Claude Pro 约 ¥140 = ¥280
VITE_SUBSCRIPTION_MONTHLY_CNY=280
VITE_BACKEND_URL=http://127.0.0.1:31002 # 统一服务 API 地址（合并了 GPU VRAM + Usage Stats + Reset Agent）

# ─────────────────── 语音对话（Voice Agent）───────────────────
# 远程电脑访问语音功能必须使用 HTTPS：
#   npm run start:v2:https
#   然后访问启动日志里的 https://内网IP:31021
#
# 浏览器优先使用内置 SpeechRecognition；如果浏览器不支持，会 fallback 到下面的本地/云端 STT。
#
# 方案 A：本地命令转写，命令 stdout 必须直接输出识别后的文本。
# {input} 会被替换为临时音频文件路径。
# 示例（按你的本机工具调整）：
# OPENCLAW_VOICE_STT_COMMAND=whisper {input} --language Chinese --model base --output_format txt --output_dir /tmp/openclaw-voice-out && cat /tmp/openclaw-voice-out/*.txt
# OPENCLAW_VOICE_STT_COMMAND=/usr/local/bin/your-stt --input {input}
OPENCLAW_VOICE_STT_COMMAND=

# 方案 B：OpenAI 兼容音频转写接口。
# 默认 endpoint 是 https://api.openai.com/v1/audio/transcriptions，默认 model 是 whisper-1。
# 如果你用其他兼容服务，改 endpoint/model/key 即可。
OPENCLAW_VOICE_STT_API_KEY=
OPENCLAW_VOICE_STT_ENDPOINT=
OPENCLAW_VOICE_STT_MODEL=whisper-1
OPENCLAW_VOICE_LANGUAGE=Chinese
OPENCLAW_VOICE_STT_TIMEOUT_MS=120000

# 语音克隆 / TTS 合成：
# 默认 auto：优先 DashScope CosyVoice，其次本地 GPT-SoVITS，再其次自定义本地 TTS 命令。
OPENCLAW_VOICE_TTS_PROVIDER=auto

# 方案 A：DashScope CosyVoice。配置后可直接用上传/录音样本创建 voice_id，并用克隆音色朗读。
OPENCLAW_VOICE_DASHSCOPE_API_KEY=
OPENCLAW_COSYVOICE_TARGET_MODEL=cosyvoice-v3-flash
OPENCLAW_COSYVOICE_TTS_MODEL=cosyvoice-v3-flash

# 方案 B：本地 GPT-SoVITS API。示例：http://127.0.0.1:9880
OPENCLAW_GPTSOVITS_URL=
OPENCLAW_GPTSOVITS_PROMPT_TEXT=你好，这是我的声音样本。

# 方案 C：自定义本地 TTS 命令。
# 必须生成音频文件；推荐在命令里使用 {output} 占位输出 wav/mp3。
# 可用占位：{text} {voiceId} {voiceName} {sample} {output}
# 示例：OPENCLAW_VOICE_TTS_COMMAND=/path/to/tts --text {text} --ref {sample} --out {output}
OPENCLAW_VOICE_TTS_COMMAND=
OPENCLAW_VOICE_TTS_TIMEOUT_MS=120000

# Agent 中文称呼配置（与 openclaw.json agents.list[].name 保持一致）
# 格式：VITE_AGENT_<id>=<中文名称>（id 中连字符用下划线替换）
# API 失败时作为降级方案
# VITE_AGENT_main=副总
# VITE_AGENT_recorder=执行秘书
# VITE_AGENT_backend=后端
# VITE_AGENT_frontend=前端
# VITE_AGENT_debugger=调试员
# VITE_AGENT_codeaudit=代码审计
# VITE_AGENT_testing=测试
# VITE_AGENT_devops=运维
# VITE_AGENT_architect=架构师
# VITE_AGENT_product=产品经理
# VITE_AGENT_requirements=需求分析
# VITE_AGENT_researchassistant=调研员
# VITE_AGENT_seo=网站运营
# VITE_AGENT_uiux=设计师
# VITE_AGENT_comfyui=Comfy
# VITE_AGENT_lesson_assistant=教研员
# VITE_AGENT_ppt_master=PPT制作
# VITE_AGENT_supervisor=监督员

# 顶部「分享」按钮复制时附带的项目地址，填你自己的 GitHub 仓库/Release 链接
VITE_SHARE_REPO_URL=
